#############################################
# Sample environment configuration (no secrets)
#############################################

# OpenAI (image generation)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Instagram Graph API
IG_USER_ID=
# One of the following will be used for the token
ACCESS_TOKEN=
IG_ACCESS_TOKEN=

# Local paths
# utils/findmusic.py requires this to be set
MUSIC_DIRECTORY=audio
NGROK_PATH=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
