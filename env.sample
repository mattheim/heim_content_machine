#############################################
# Sample environment configuration (no secrets)
#############################################

# OpenAI (image generation)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Instagram Graph API
IG_USER_ID=
# One of the following will be used for the token
ACCESS_TOKEN=
IG_ACCESS_TOKEN=
VIDEO_PUBLISH_DELAY_SECONDS=
VIDEO_PUBLISH_RETRIES=
VIDEO_PUBLISH_RETRY_DELAY_SECONDS=

# Local paths
# utils/findmusic.py requires this to be set
MUSIC_DIRECTORY=
NGROK_PATH=

# Prompt provider
# Choose one: strategos or ollama
PROMPT_PROVIDER=

# Strategos (local prompt orchestration)
STRATEGOS_BASE_URL=
STRATEGOS_TIMEOUT_MS=
# Optional override if you want Strategos to run against a different project path
STRATEGOS_PROJECT_PATH=

# Ollama (local LLM)
OLLAMA_MODEL=
