#############################################
# Sample environment configuration (no secrets)
#############################################

# OpenAI (for image generation)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Ollama (local LLM model selection)
OLLAMA_MODEL=deepseek-r1:8b

# Local paths
MUSIC_DIRECTORY=/absolute/path/to/your/music/folder
NGROK_PATH=/absolute/path/to/ngrok

# Instagram Graph API
IG_USER_ID=
IG_ACCESS_TOKEN=

# Instagram login (if used by Myth_Bot)
IG_USERNAME=
IG_PASSWORD=

# Optional Instagram app settings
IG_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_NAME=
IG_GRAPH_API_ACCESS_TOKEN=
PYTHIA_TOKEN=

# Optional defaults for Myth_Bot upload
IG_IMAGE_PATH=
IG_IMAGE_CAPTION=
